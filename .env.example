# ── LLM Providers (at least one required) ───────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=                          # Optional, for Claude models
DEFAULT_MODEL=gpt-4-turbo-preview

# ── External CRM & Enrichment Integrations ───────────────────────────────────
APOLLO_API_KEY=                             # Get from: https://app.apollo.io/#/settings/integrations/api
HUBSPOT_ACCESS_TOKEN=                       # Get from: HubSpot → Settings → Integrations → Private Apps
SLACK_BOT_TOKEN=xoxb-your-slack-token       # Get from: https://api.slack.com/apps
GMAIL_CLIENT_SECRET_FILE=credentials.json  # OAuth2 file from Google Cloud Console

# ── Infrastructure ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0          # For enrichment caching
DATABASE_URL=sqlite:///./salesiq.db        # For session persistence
CACHE_TTL_SECONDS=604800                    # 7 days

# ── Application Settings ─────────────────────────────────────────────────────
API_SECRET_KEY=change-this-to-a-long-random-secret  # Used for X-API-Key header auth
ENVIRONMENT=development                     # development | staging | production
RATE_LIMIT_PER_MINUTE=10

# ── Mock Mode (set to false when real API keys are configured) ────────────────
USE_MOCK_INTEGRATIONS=true                  # true = safe demo mode | false = live API calls

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR

# ── Observability (Optional — recommended for production) ────────────────────
# SENTRY_DSN=https://...@sentry.io/...     # Uncomment for error tracking
# LANGCHAIN_TRACING_V2=true               # Uncomment for LangSmith LLM tracing
# LANGCHAIN_API_KEY=ls__your-key-here     # Required if LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=salesiq-crm          # Project name in LangSmith dashboard
